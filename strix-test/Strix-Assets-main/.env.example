# API server
PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/strix
NODE_ENV=production

# ─── أمان لوحة التحكم (Dashboard security) ───
# سر توقيع توكنات الأدمن (سلسلة عشوائية طويلة >= 32 حرف). أنشئه بـ: openssl rand -hex 32
AUTH_SECRET=
# بيانات دخول الأدمن للوحة التحكم
ADMIN_EMAIL=admin@strix.sa
ADMIN_PASSWORD=
# أصل (أصول) لوحة التحكم المسموح بها لـ CORS (مفصولة بفواصل). مثال:
# DASHBOARD_ORIGIN=https://dashboard.strix.sa,https://admin.strix.sa
DASHBOARD_ORIGIN=

# Expo app
# Include the /api suffix because the Express server mounts routes under /api.
EXPO_PUBLIC_STRIX_API_URL=http://localhost:3000/api

# Legacy fallback. Keep empty when using the Strix API server.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
